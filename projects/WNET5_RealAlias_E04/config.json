{
    "epoch_train": 30000,
    "step_per_epoch": 1,
    "learning_rate": 0.02,
    "use_model": "WaveNet5",
    "dataset_type": "Alias",
    "data_path": "data/ALIA",
    "kernal_units": 6,
    "use_best_val_weights": true,
    "auto_lr_decay_steps": 1000,
    "model_subcfg": {
        "init_center_freqs": [8, 25, 50, 85, 120, 180],
        "init_quality_factors": [3.0, 4.0, 5.0, 6.0, 7.0, 8.0],
        "post_dense": true,
        "post_dense_activation": "relu",
        "post_dense_units": 8,
        "post_dense_layers": 4,
        "use_dense_bias": true
    },
    "target_sweep": 0,
    "use_predict_features": true
}