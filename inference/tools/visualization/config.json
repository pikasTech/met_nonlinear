{
  "plots": {
    "overview": true,
    "layer_analysis": true,
    "channel_analysis": true,
    "distribution": true,
    "statistics": true,
    "rms_analysis": false
  },
  "figure": {
    "dpi": 300,
    "figsize": [10, 8],
    "font_size": 12,
    "style": "seaborn-v0_8-paper"
  },
  "colors": {
    "baseline": "#E74C3C",
    "compensated": "#27AE60", 
    "improvement": "#3498DB",
    "colormap": "viridis"
  },
  "statistics": {
    "confidence_level": 0.95,
    "show_pvalues": true,
    "test_type": "wilcoxon"
  },
  "output": {
    "format": "png",
    "raw_data_format": "json",
    "latex_tables": true,
    "save_raw_data": true
  }
}